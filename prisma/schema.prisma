datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TripStatus {
  SEARCHING
  MATCHED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

model Trip {
  id              String     @id @default(uuid())
  passenger_id    String 
  driver_id       String?
  status          TripStatus @default(SEARCHING)
  origin_lat      Float
  origin_lng      Float
  dest_lat        Float
  dest_lng        Float
  estimated_price Decimal    @db.Decimal(10, 2)
  final_price     Decimal?   @db.Decimal(10, 2)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
}

model PricingZone {
  id           String    @id @default(uuid())
  h3_index     String    @unique
  multiplier   Decimal   @db.Decimal(4, 2)
  active_until DateTime
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}
